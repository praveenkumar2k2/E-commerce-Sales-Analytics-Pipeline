{
  "evaluation": {
    "source": {
      "name": "total_orders",
      "display": "total_orders",
      "aggregation": "AGGREGATION_UNSPECIFIED"
    },
    "comparison_operator": "LESS_THAN",
    "threshold": {
      "value": {
        "double_value": 2.0
      }
    },
    "notification": {
      "retrigger_seconds": 1
    }
  },
  "schedule": {
    "quartz_cron_schedule": "35 * * * * ?",
    "timezone_id": "Asia/Calcutta"
  },
  "query_lines": [
    "SELECT ",
    "COUNT(DISTINCT order_id) AS total_orders",
    "FROM ecommerce_catalog.gold.fact_sales",
    "WHERE order_date = (",
    "    SELECT MAX(order_date)",
    "    FROM ecommerce_catalog.gold.fact_sales",
    ");"
  ]
}
