{
  "datasets": [
    {
      "name": "5c8d9a27",
      "displayName": "fact_sales",
      "queryLines": [
        "SELECT * FROM ecommerce_catalog.gold.fact_sales"
      ]
    },
    {
      "name": "96516e00",
      "displayName": "Top Customers by Purchase Count Summary",
      "queryLines": [
        "--Customer Purchase Frequency\r\n",
        "SELECT \r\n",
        "customer_id,\r\n",
        "COUNT(order_id) AS total_orders\r\n",
        "FROM ecommerce_catalog.gold.fact_sales\r\n",
        "GROUP BY customer_id\r\n",
        "ORDER BY total_orders DESC\r\n",
        "LIMIT 20;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "ec1c9fea",
      "displayName": "Repeat vs One-Time Customers",
      "queryLines": [
        "--Repeat vs One-Time Customers\r\n",
        "\r\n",
        "SELECT \r\n",
        "CASE \r\n",
        "WHEN order_count = 1 THEN 'One Time'\r\n",
        "ELSE 'Repeat'\r\n",
        "END AS customer_type,\r\n",
        "COUNT(*) AS customers\r\n",
        "FROM (\r\n",
        "SELECT customer_id, COUNT(order_id) AS order_count\r\n",
        "FROM ecommerce_catalog.gold.fact_sales\r\n",
        "GROUP BY customer_id\r\n",
        ") t\r\n",
        "GROUP BY customer_type;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "71e84ab4",
      "displayName": "Average Order Value by Customer",
      "queryLines": [
        "--Average Order Value by Customer\r\n",
        "\r\n",
        "SELECT \r\n",
        "customer_id,\r\n",
        "AVG(payment_value) AS avg_order_value\r\n",
        "FROM ecommerce_catalog.gold.fact_sales\r\n",
        "GROUP BY customer_id\r\n",
        "ORDER BY avg_order_value DESC\r\n",
        "LIMIT 20;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "8873e8f1",
      "displayName": "Customer Distribution by State",
      "queryLines": [
        "---Customer Distribution by State\r\n",
        " \r\n",
        "SELECT\r\n",
        "customer_state,\r\n",
        "COUNT(DISTINCT customer_id) AS total_customers\r\n",
        "FROM ecommerce_catalog.gold.dim_customers\r\n",
        "GROUP BY customer_state\r\n",
        "ORDER BY total_customers DESC;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "b936a6c8",
      "displayName": "Top Customers by Revenue",
      "queryLines": [
        "---Top Customers by Revenue\r\n",
        "\r\n",
        "SELECT\r\n",
        "customer_id,\r\n",
        "SUM(payment_value) AS total_spent\r\n",
        "FROM ecommerce_catalog.gold.fact_sales\r\n",
        "GROUP BY customer_id\r\n",
        "ORDER BY total_spent DESC\r\n",
        "LIMIT 10;\r\n"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    }
  ],
