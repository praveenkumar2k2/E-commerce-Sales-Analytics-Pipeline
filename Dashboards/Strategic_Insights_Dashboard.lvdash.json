{
  "datasets": [
    {
      "name": "82d47c8a",
      "displayName": "Monthly Product Demand Trend",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "DATE_TRUNC('month', o.order_purchase_timestamp) AS order_month,\n",
        "\n",
        "CONCAT(\n",
        "INITCAP(REPLACE(p.product_category_name,'_',' ')),\n",
        "'  ( ',\n",
        "INITCAP(REPLACE(t.product_category_name_english,'_',' ')),\n",
        "' )'\n",
        ") AS product_category,\n",
        "\n",
        "QUARTER(o.order_purchase_timestamp) AS order_quarter,\n",
        "\n",
        "COUNT(fs.product_id) AS items_sold\n",
        "\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id\n",
        "JOIN main_workspace.gold.dim_products p\n",
        "ON fs.product_id = p.product_id\n",
        "JOIN main_workspace.silver.product_category_translation t\n",
        "ON p.product_category_name = t.product_category_name\n",
        "\n",
        "GROUP BY\n",
        "DATE_TRUNC('month', o.order_purchase_timestamp),\n",
        "QUARTER(o.order_purchase_timestamp),\n",
        "p.product_category_name,\n",
        "t.product_category_name_english\n",
        "\n",
        "ORDER BY order_month"
      ]
    },
    {
      "name": "1e563c58",
      "displayName": "Daily Sales Volume Trend",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "DATE(o.order_purchase_timestamp) AS order_date,\n",
        "CONCAT(\n",
        "INITCAP(REPLACE(p.product_category_name,'_',' ')),\n",
        "'  ( ',\n",
        "INITCAP(REPLACE(t.product_category_name_english,'_',' ')),\n",
        "' )'\n",
        ") AS product_category,\n",
        "COUNT(fs.product_id) AS items_sold\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id\n",
        "JOIN main_workspace.gold.dim_products p\n",
        "ON fs.product_id = p.product_id\n",
        "JOIN main_workspace.silver.product_category_translation t\n",
        "ON p.product_category_name = t.product_category_name\n",
        "GROUP BY\n",
        "DATE(o.order_purchase_timestamp),\n",
        "p.product_category_name,\n",
        "t.product_category_name_english\n",
        "ORDER BY order_date"
      ]
    },
    {
      "name": "1d8629e0",
      "displayName": "Shipping Cost Impact",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "ROUND(\n",
        "SUM(freight_value) / SUM(price) * 100,2\n",
        ") AS shipping_cost_percentage\n",
        "FROM main_workspace.gold.fact_sales"
      ]
    },
    {
      "name": "50f76215",
      "displayName": "Top Product Categories by Average Price",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "CONCAT(\n",
        "INITCAP(REPLACE(p.product_category_name,'_',' ')),\n",
        "'  ( ',\n",
        "INITCAP(REPLACE(t.product_category_name_english,'_',' ')),\n",
        "' )'\n",
        ") AS product_category,\n",
        "ROUND(AVG(fs.price),2) AS avg_price\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.dim_products p\n",
        "ON fs.product_id = p.product_id\n",
        "JOIN main_workspace.silver.product_category_translation t\n",
        "ON p.product_category_name = t.product_category_name\n",
        "GROUP BY p.product_category_name, t.product_category_name_english\n",
        "ORDER BY avg_price DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "a8b1da59",
      "displayName": "Top 10 Customers Revenue Share",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "WITH customer_revenue AS (\n",
        "SELECT\n",
        "o.customer_id,\n",
        "SUM(fs.price + fs.freight_value) AS revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id\n",
        "GROUP BY o.customer_id\n",
        "),\n",
        "\n",
        "top_customers AS (\n",
        "SELECT\n",
        "SUM(revenue) AS top_revenue\n",
        "FROM (\n",
        "SELECT revenue\n",
        "FROM customer_revenue\n",
        "ORDER BY revenue DESC\n",
        "LIMIT 10\n",
        ")\n",
        "),\n",
        "\n",
        "total_revenue AS (\n",
        "SELECT SUM(revenue) AS total_rev\n",
        "FROM customer_revenue\n",
        ")\n",
        "\n",
        "SELECT\n",
        "ROUND((top_revenue / total_rev) * 100,2) AS top_customer_revenue_share\n",
        "FROM top_customers, total_revenue"
      ]
    },
    {
      "name": "3bfcce1c",
      "displayName": "Revenue Concentration by Category",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "CONCAT(\n",
        "INITCAP(REPLACE(p.product_category_name,'_',' ')),\n",
        "'  ( ',\n",
        "INITCAP(REPLACE(t.product_category_name_english,'_',' ')),\n",
        "' )'\n",
        ") AS product_category,\n",
        "SUM(fs.price + fs.freight_value) AS total_revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.dim_products p\n",
        "ON fs.product_id = p.product_id\n",
        "JOIN main_workspace.silver.product_category_translation t\n",
        "ON p.product_category_name = t.product_category_name\n",
        "GROUP BY p.product_category_name, t.product_category_name_english\n",
        "ORDER BY total_revenue DESC\n",
        "LIMIT 10"
      ]
    }
  ],
