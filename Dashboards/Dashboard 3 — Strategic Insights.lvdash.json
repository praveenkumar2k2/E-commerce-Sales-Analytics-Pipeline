{
  "datasets": [
    {
      "name": "930abc8d",
      "displayName": "fact_sales",
      "queryLines": [
        "SELECT * FROM ecommerce_catalog.gold.fact_sales"
      ]
    },
    {
      "name": "f444f336",
      "displayName": "Seller Performance",
      "queryLines": [
        "--bar chart\r\n",
        "--Seller Performance\r\n",
        "SELECT \r\n",
        "seller_id,\r\n",
        "SUM(product_price) AS revenue,\r\n",
        "COUNT(DISTINCT order_id) AS orders\r\n",
        "FROM ecommerce_catalog.gold.fact_sales\r\n",
        "GROUP BY seller_id\r\n",
        "ORDER BY revenue DESC\r\n",
        "LIMIT 10;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "594dab2b",
      "displayName": "Average Delivery Time Analysis for Ecommerce Orders",
      "queryLines": [
        "--counter\r\n",
        "--Delivery Performance\r\n",
        "SELECT \r\n",
        "AVG(DATEDIFF(order_delivered_customer_date, order_purchase_timestamp)) \r\n",
        "AS avg_delivery_days\r\n",
        "FROM ecommerce_catalog.gold.dim_orders;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "fb1ab813",
      "displayName": "Average Freight Cost Analysis Summary",
      "queryLines": [
        "--counter\r\n",
        "--Shipping Cost Impact\r\n",
        "SELECT \r\n",
        "AVG(freight_value) AS avg_shipping_cost\r\n",
        "FROM ecommerce_catalog.gold.fact_sales;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    }
  ],
