{
  "datasets": [
    {
      "name": "6b677be2",
      "displayName": "Ecommerce Gold Sales Sample Data",
      "queryLines": [
        "select * from ecommerce_catalog.gold.fact_sales limit 100"
      ]
    },
    {
      "name": "6b48a9bf",
      "displayName": "Total Revenue",
      "queryLines": [
        "SELECT SUM(product_price + freight_value) AS total_revenue FROM ecommerce_catalog.gold.fact_sales;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "2647ba70",
      "displayName": "Total Orders",
      "queryLines": [
        "SELECT COUNT(DISTINCT order_id) AS total_orders FROM ecommerce_catalog.gold.fact_sales;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "4aabeb8c",
      "displayName": "Average Order Value",
      "queryLines": [
        "SELECT SUM(payment_value)/COUNT(DISTINCT order_id) AS avg_order_value FROM ecommerce_catalog.gold.fact_sales;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "455d9ba3",
      "displayName": "Revenue Trend (Monthly)",
      "queryLines": [
        "--Revenue Trend (Monthly)\r\n",
        "-- line chart\r\n",
        "SELECT \r\n",
        "d.year,\r\n",
        "d.month,\r\n",
        "SUM(f.product_price + f.freight_value) AS revenue\r\n",
        "FROM ecommerce_catalog.gold.fact_sales f\r\n",
        "JOIN ecommerce_catalog.gold.dim_date d\r\n",
        "ON f.order_date = d.date\r\n",
        "GROUP BY d.year, d.month\r\n",
        "ORDER BY d.year, d.month;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "ed7c75da",
      "displayName": "Top Selling Products",
      "queryLines": [
        "--Top Selling Products\r\n",
        "-- Bar chart\r\n",
        "SELECT \r\n",
        "p.product_category_name,\r\n",
        "SUM(f.product_price + f.freight_value) AS revenue\r\n",
        "FROM ecommerce_catalog.gold.fact_sales f\r\n",
        "JOIN ecommerce_catalog.gold.dim_products p\r\n",
        "ON f.product_id = p.product_id\r\n",
        "GROUP BY p.product_category_name\r\n",
        "ORDER BY revenue DESC\r\n",
        "LIMIT 10;"
      ],
      "catalog": "ecommerce_catalog",
      "schema": "gold"
    },
    {
      "name": "3e064f40",
      "displayName": "Sales by Region",
      "queryLines": [
        "--Bar chart\r\n",
        "--Sales by Region\r\n",
        "SELECT\r\n",
        "c.customer_state,\r\n",
        "COUNT(DISTINCT f.order_id) AS total_orders\r\n",
        "FROM ecommerce_catalog.gold.fact_sales f\r\n",
        "JOIN ecommerce_catalog.gold.dim_customers c\r\n",
        "ON f.customer_id = c.customer_id\r\n",
        "GROUP BY c.customer_state\r\n",
        "ORDER BY total_orders DESC;"
      ]
    }
  ],
