{
  "datasets": [
    {
      "name": "8b15f71a",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "COUNT(DISTINCT customer_id) AS total_customers\n",
        "FROM main_workspace.gold.dim_customers"
      ]
    },
    {
      "name": "e9c02923",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "COUNT(DISTINCT customer_city) AS total_cities\n",
        "FROM main_workspace.gold.dim_customers"
      ]
    },
    {
      "name": "e59844ec",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "COUNT(DISTINCT customer_state) AS total_states\n",
        "FROM main_workspace.gold.dim_customers"
      ]
    },
    {
      "name": "f9321ba8",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "ROUND(\n",
        "SUM(fs.price + fs.freight_value) /\n",
        "COUNT(DISTINCT o.customer_id),2\n",
        ") AS avg_customer_spend\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id"
      ]
    },
    {
      "name": "7bfda81b",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "DATE(o.order_purchase_timestamp) AS order_date,\n",
        "SUM(fs.price + fs.freight_value) AS customer_revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id\n",
        "GROUP BY DATE(o.order_purchase_timestamp)\n",
        "ORDER BY order_date;"
      ]
    },
    {
      "name": "2b65ff31",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "c.customer_city,\n",
        "c.customer_state,\n",
        "SUM(fs.price + fs.freight_value) AS total_revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id\n",
        "JOIN main_workspace.gold.dim_customers c\n",
        "ON o.customer_id = c.customer_id\n",
        "GROUP BY c.customer_city, c.customer_state\n",
        "ORDER BY total_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "d971e147",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "CASE\n",
        "WHEN total_spend >= 500 THEN 'High Value Customers'\n",
        "WHEN total_spend BETWEEN 200 AND 499 THEN 'Medium Value Customers'\n",
        "ELSE 'Low Value Customers'\n",
        "END AS customer_segment,\n",
        "COUNT(*) AS customer_count\n",
        "FROM (\n",
        "SELECT\n",
        "o.customer_id,\n",
        "SUM(fs.price + fs.freight_value) AS total_spend\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id\n",
        "GROUP BY o.customer_id\n",
        ") t\n",
        "GROUP BY customer_segment"
      ]
    }
  ],
