    {
      "name": "60ac7e26",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "SUM(price + freight_value) /\n",
        "COUNT(DISTINCT order_id) AS avg_order_value\n",
        "FROM main_workspace.gold.fact_sales"
      ]
    },
    {
      "name": "70287266",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "p.product_category_name AS product_category,\n",
        "SUM(fs.price + fs.freight_value) AS total_revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.dim_products p\n",
        "ON fs.product_id = p.product_id\n",
        "GROUP BY p.product_category_name\n",
        "ORDER BY total_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "d597cfee",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "INITCAP(REPLACE(t.product_category_name_english, '_', ' ')) AS product_category,\n",
        "SUM(fs.price + fs.freight_value) AS total_revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.dim_products p\n",
        "ON fs.product_id = p.product_id\n",
        "JOIN main_workspace.silver.product_category_translation t\n",
        "ON p.product_category_name = t.product_category_name\n",
        "GROUP BY t.product_category_name_english\n",
        "ORDER BY total_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "9c7e6ee8",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "CONCAT(\n",
        "INITCAP(REPLACE(p.product_category_name,'_',' ')),\n",
        "' (',\n",
        "INITCAP(REPLACE(t.product_category_name_english,'_',' ')),\n",
        "')'\n",
        ") AS product_category,\n",
        "SUM(fs.price + fs.freight_value) AS total_revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.dim_products p\n",
        "ON fs.product_id = p.product_id\n",
        "JOIN main_workspace.silver.product_category_translation t\n",
        "ON p.product_category_name = t.product_category_name\n",
        "GROUP BY p.product_category_name, t.product_category_name_english\n",
        "ORDER BY total_revenue DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "89ac0dbf",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "DATE(o.order_purchase_timestamp) AS order_date,\n",
        "SUM(fs.price + fs.freight_value) AS total_revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id\n",
        "GROUP BY DATE(o.order_purchase_timestamp)\n",
        "ORDER BY order_date"
      ]
    },
    {
      "name": "2b45f128",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "DATE(o.order_purchase_timestamp) AS order_date,\n",
        "SUM(fs.price + fs.freight_value) AS total_revenue\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.fact_orders o\n",
        "ON fs.order_id = o.order_id\n",
        "GROUP BY DATE(o.order_purchase_timestamp)\n",
        "ORDER BY order_date\n",
        "\n"
      ]
    },
    {
      "name": "95fe860c",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "CASE\n",
        "WHEN seller_revenue >= 200000 THEN 'High Performing Sellers'\n",
        "WHEN seller_revenue BETWEEN 100000 AND 199999 THEN 'Medium Performing Sellers'\n",
        "ELSE 'Low Performing Sellers'\n",
        "END AS seller_segment,\n",
        "COUNT(*) AS seller_count\n",
        "FROM (\n",
        "SELECT\n",
        "seller_id,\n",
        "SUM(price + freight_value) AS seller_revenue\n",
        "FROM main_workspace.gold.fact_sales\n",
        "GROUP BY seller_id\n",
        ") s\n",
        "GROUP BY seller_segment\n",
        "ORDER BY seller_segment DESC"
      ]
    },
    {
      "name": "7ae36a4e",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "CASE\n",
        "WHEN seller_revenue >= 200000 THEN 'High Performing Sellers'\n",
        "WHEN seller_revenue BETWEEN 100000 AND 199999 THEN 'Medium Performing Sellers'\n",
        "ELSE 'Low Performing Sellers'\n",
        "END AS seller_segment,\n",
        "COUNT(*) AS seller_count\n",
        "FROM (\n",
        "SELECT\n",
        "seller_id,\n",
        "SUM(price + freight_value) AS seller_revenue\n",
        "FROM main_workspace.gold.fact_sales\n",
        "GROUP BY seller_id\n",
        ") s\n",
        "GROUP BY seller_segment\n",
        "ORDER BY seller_segment DESC"
      ]
    },
    {
      "name": "62197ccf",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "'Product Revenue' AS revenue_type,\n",
        "SUM(price) AS amount\n",
        "FROM main_workspace.gold.fact_sales\n",
        "\n",
        "UNION ALL\n",
        "\n",
        "SELECT\n",
        "'Shipping Revenue' AS revenue_type,\n",
        "SUM(freight_value) AS amount\n",
        "FROM main_workspace.gold.fact_sales"
      ]
    },
    {
      "name": "23ebabb0",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `gold`;\n",
        "\n",
        "SELECT\n",
        "'Product Revenue' AS revenue_type,\n",
        "SUM(price) AS amount\n",
        "FROM main_workspace.gold.fact_sales\n",
        "\n",
        "UNION ALL\n",
        "\n",
        "SELECT\n",
        "'Shipping Revenue' AS revenue_type,\n",
        "SUM(freight_value) AS amount\n",
        "FROM main_workspace.gold.fact_sales"
      ]
    },
    {
      "name": "21517244",
      "displayName": "Untitled dataset",
      "queryLines": [
        "USE CATALOG `main_workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "CONCAT(\n",
        "    INITCAP(REPLACE(p.product_category_name,'_',' ')),\n",
        "    '  ( ',\n",
        "    INITCAP(REPLACE(t.product_category_name_english,'_',' ')),\n",
        "    ' )'\n",
        ") AS product_category,\n",
        "ROUND(AVG(fs.price),2) AS avg_product_price\n",
        "FROM main_workspace.gold.fact_sales fs\n",
        "JOIN main_workspace.gold.dim_products p\n",
        "ON fs.product_id = p.product_id\n",
        "JOIN main_workspace.silver.product_category_translation t\n",
        "ON p.product_category_name = t.product_category_name\n",
        "GROUP BY p.product_category_name, t.product_category_name_english\n",
        "ORDER BY avg_product_price DESC\n",
        "LIMIT 10"
      ]
    }
  ],
